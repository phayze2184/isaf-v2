---
import "../../styles/tokens.css";
import "../../styles/global.css";
import "../../styles/typography.css";
import footerBgDesktop from "../../assets/images/footer-bg-desktop.jpg";
import footerBgMobile from "../../assets/images/footer-bg-mobile.jpg";
import logoIsaf from "../../assets/images/logo-isaf.png";
import linkedinIcon from "../../assets/icons/linkedin-icon.svg";
import facebookIcon from "../../assets/icons/facebook-icon.svg";

const contactCards = [
  {
    title: "Contact sediu",
    className: "footer-contact-card--office",
    details: [
      { label: "+40 21 220 80 75", href: "tel:+40212208075" },
      { label: "office@isaf.ro", href: "mailto:office@isaf.ro" },
    ],
  },
  {
    title: "Resurse umane",
    className: "footer-contact-card--hr",
    details: [
      { label: "+40 725 809 842", href: "tel:+40725809842" },
      { label: "+40 756 047 832", href: "tel:+40756047832" },
    ],
  },
  {
    title: "Adresă sediu",
    className: "footer-contact-card--address-office",
    details: [
      {
        label: "Str. Lugoj nr. 68, C.P. 012212, Sector 1, București, România",
        href: "",
      },
    ],
  },
  {
    title: "Adresă fabrică",
    className: "footer-contact-card--address-factory",
    details: [
      {
        label: "Str. Copșa Mică nr 25, C.P. 014619\nSector 1, București, România",
        href: "",
      },
    ],
  },
];

const footerLinks = [
  { label: "Despre ISAF", href: "#about" },
  { label: "Soluții", href: "#solutions" },
  { label: "Producție", href: "#production" },
  { label: "Cariere", href: "#contact" },
];
---

<footer
  id="contact"
  class="site-footer"
  style={`--footer-bg-mobile: url("${footerBgMobile.src}"); --footer-bg-desktop: url("${footerBgDesktop.src}")`}
>
  <div class="footer-wrapper">
    <div class="footer-contact-cards">
      {
        contactCards.map((card) => (
          <section class={`footer-contact-card ${card.className}`}>
            <div class="footer-card-title">
              <h2>{card.title}</h2>
              <span class="footer-title-line" aria-hidden="true"></span>
            </div>

            <div class="footer-card-details">
              {
                card.details.map((detail) =>
                  detail.href ? (
                    <a href={detail.href}>{detail.label}</a>
                  ) : (
                    <p>{detail.label}</p>
                  ),
                )
              }
            </div>
          </section>
        ))
      }
    </div>

    <div class="footer-links-block">
      <a class="footer-logo" href="/" aria-label="ISAF home">
        <img src={logoIsaf.src} alt="ISAF" loading="lazy" />
      </a>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-link-wrapper">
          {
            footerLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))
          }
        </div>
      </nav>
    </div>

    <div class="footer-copyright-block">
      <div class="footer-social" aria-label="Social media">
        <a
          href="https://www.linkedin.com/company/isaf-sa-san-grup-romania/"
          aria-label="ISAF on LinkedIn"
          style={`--footer-social-icon: url("${linkedinIcon.src}")`}
        >
          <span class="footer-social-icon" aria-hidden="true"></span>
        </a>
        <a
          href="https://www.facebook.com/isaf.sa/"
          aria-label="ISAF on Facebook"
          style={`--footer-social-icon: url("${facebookIcon.src}")`}
        >
          <span class="footer-social-icon" aria-hidden="true"></span>
        </a>
      </div>

      <div class="footer-copyright-wrap">
        <p class="footer-copyright">
          <span class="footer-copyright-mark">®</span>
          <span>2026 ISAF. Toate drepturile rezervate.</span>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    inline-size: 100%;
    overflow: hidden;
    background: var(--color-black);
    color: var(--color-text-muted-dark);
  }

  .site-footer::before,
  .site-footer::after {
    position: absolute;
    content: "";
    pointer-events: none;
  }

  .site-footer::before {
    inset-block-start: -13%;
    inset-inline: 0;
    block-size: 63.27%;
    background: var(--footer-bg-mobile) center / cover no-repeat;
  }

  .site-footer::after {
    inset: 0;
    background: oklch(0% 0 0 / 80%);
  }

  .footer-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-15);
    inline-size: min(100%, 24.5625rem);
    overflow: hidden;
    padding: var(--spacing-15) var(--spacing-10);
  }

  .footer-contact-cards {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-8);
  }

  .footer-contact-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: none;
    gap: var(--spacing-3);
    inline-size: 17.1875rem;
  }

  .footer-contact-card--office {
    block-size: 7.25rem;
  }

  .footer-contact-card--address-factory {
    block-size: 6.5rem;
  }

  .footer-card-title {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: none;
    justify-content: center;
    gap: 0.375rem;
    inline-size: 100%;
  }

  .footer-card-title h2 {
    margin: 0;
    color: var(--color-white);
    font-family: "Atkinson Hyperlegible Mono", monospace;
    font-size: var(--font-size-kpi);
    font-weight: var(--font-weight-label);
    line-height: var(--line-height-label);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
  }

  .footer-title-line {
    position: relative;
    flex: none;
    display: block;
    inline-size: 2.25rem;
    block-size: 0.125rem;
    overflow: hidden;
    background: var(--color-amber);
  }

  .footer-card-details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    inline-size: 100%;
    overflow: hidden;
  }

  .footer-contact-card--office .footer-card-details {
    inline-size: 14.6875rem;
  }

  .footer-card-details a,
  .footer-card-details p {
    display: flex;
    align-items: center;
    margin: 0;
    color: var(--color-text-muted-dark);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-18);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    white-space: pre-line;
  }

  .footer-links-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-6);
  }

  .footer-logo {
    display: block;
    inline-size: 11.875rem;
    block-size: 4.625rem;
  }

  .footer-logo img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .footer-link-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--spacing-6);
  }

  .footer-nav a {
    color: var(--color-text-inverse-muted);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-label);
    line-height: var(--line-height-130);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .footer-card-details a:focus-visible,
  .footer-logo:focus-visible,
  .footer-nav a:focus-visible,
  .footer-social a:focus-visible {
    outline: var(--border-medium) solid var(--color-amber);
    outline-offset: var(--spacing-1);
  }

  .footer-copyright-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-4);
    inline-size: 100%;
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-6);
    inline-size: 100%;
  }

  .footer-social a {
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: var(--spacing-3);
    border: var(--border-hairline) solid var(--color-text-inverse-muted);
    color: var(--color-text-inverse-muted);
    transition: transform 160ms ease;
  }

  .footer-social a:hover {
    transform: translateY(-0.125rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-social a {
      transition-duration: 0.01ms;
    }

    .footer-social a:hover {
      transform: none;
    }
  }

  .footer-social-icon {
    inline-size: var(--size-icon-lg);
    block-size: var(--size-icon-lg);
    background: currentColor;
    -webkit-mask: var(--footer-social-icon) center / contain no-repeat;
    mask: var(--footer-social-icon) center / contain no-repeat;
  }

  .footer-copyright-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2);
    inline-size: 100%;
  }

  .footer-copyright {
    display: flex;
    gap: 0.25rem;
    margin: 0;
    color: var(--color-slate-500);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    letter-spacing: var(--letter-spacing-body);
    white-space: nowrap;
  }

  @media (min-width: 64em) {
    .site-footer {
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-15);
      padding-block: 7.5rem var(--spacing-15);
    }

    .site-footer::before {
      inset: 0;
      block-size: auto;
      background: var(--footer-bg-desktop) center / cover no-repeat;
    }

    .footer-wrapper {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "contacts contacts"
        "brand copyright";
      align-items: center;
      gap: var(--spacing-15);
      inline-size: min(100%, 75rem);
      padding: 0;
      overflow: visible;
    }

    .footer-contact-cards {
      grid-area: contacts;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0;
      inline-size: 100%;
    }

    .footer-contact-card,
    .footer-contact-card--office,
    .footer-contact-card--address-factory {
      flex: 0 0 17.1875rem;
      block-size: auto;
    }

    .footer-contact-card--office,
    .footer-contact-card--address-factory {
      align-self: stretch;
    }

    .footer-links-block {
      grid-area: brand;
      flex-direction: row;
      align-items: center;
      gap: var(--spacing-8);
    }

    .footer-link-wrapper {
      flex-direction: row;
      align-items: center;
      gap: var(--spacing-6);
    }

    .footer-nav a {
      display: flex;
      align-items: center;
      gap: var(--spacing-6);
    }

    .footer-nav a:not(:last-child)::after {
      content: "";
      flex: none;
      inline-size: var(--spacing-6);
      block-size: var(--border-medium);
      background: var(--color-red);
      transform: rotate(-45deg);
      transform-origin: center;
    }

    .footer-copyright-block {
      grid-area: copyright;
      align-items: flex-end;
      justify-content: center;
      inline-size: auto;
    }

    .footer-social {
      align-self: center;
      justify-content: center;
      gap: var(--spacing-3);
    }

    .footer-copyright-wrap {
      padding: 0;
    }

    .footer-copyright {
      color: var(--color-text-inverse-muted);
      font-size: var(--font-size-body-sm);
    }
  }
</style>

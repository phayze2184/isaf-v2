---
import "../../styles/tokens.css";
import "../../styles/global.css";
import "../../styles/typography.css";
import logoIsaf from "../../assets/images/logo-isaf.png";
import Button from "../ui/Button.astro";
import {
  getAlternateLocale,
  getLocalizedPath,
  normalizeLocale,
  type RouteKey,
} from "../../i18n/routing";
import { getSiteContent } from "../../i18n/site";

const { lang = "ro", route = "home" } = Astro.props;
const locale = normalizeLocale(lang);
const routeKey = route as RouteKey;
const alternateLocale = getAlternateLocale(locale);
const homeHref = getLocalizedPath(locale, "home");
const languageHref = getLocalizedPath(alternateLocale, routeKey);
const certificationsHref = getLocalizedPath(locale, "certifications");
const copy = getSiteContent(locale).header;
---

<header class="header">
  <div class="navbar" data-navbar>
    <div class="navbar-left">
      <a class="brand" href={homeHref} aria-label={copy.homeLabel}>
        <img
          class="brand-logo"
          src={logoIsaf.src}
          alt="ISAF"
          width="1000"
          height="394"
        />
      </a>

      <div class="tagline" aria-hidden="true">
        <span>on track</span>
        <span>for the future</span>
      </div>
    </div>

    <nav id="primary-navigation" class="primary-nav" aria-label={copy.navLabel}>
      <a href={`${homeHref}#about`}>{copy.about}</a>
      <a href={`${homeHref}#solutions`}>{copy.solutions}</a>
      <a href={`${homeHref}#production`}>{copy.production}</a>
      <a href={certificationsHref}>{copy.certifications}</a>
    </nav>

    <div class="navbar-actions">
      <a
        class="language-toggle"
        href={languageHref}
        hreflang={alternateLocale}
        aria-label={copy.switchLanguage}
      >
        <span>{copy.nextLanguage}</span>
      </a>
      <div class="contact-action">
        <Button
          href={`${homeHref}#contact`}
          variant="secondary"
          class="header-contact"
        >
          <span>{copy.contact}</span>
        </Button>
      </div>

      <button
        class="menu-toggle"
        type="button"
        aria-label={copy.menuOpen}
        aria-expanded="false"
        aria-controls="primary-navigation"
        data-menu-open-label={copy.menuOpen}
        data-menu-close-label={copy.menuClose}
        data-menu-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<script>
  {
    const navbar = document.querySelector("[data-navbar]");
    const menuToggle = document.querySelector("[data-menu-toggle]");
    const primaryNav = document.querySelector("#primary-navigation");

    if (
      navbar instanceof HTMLElement &&
      menuToggle instanceof HTMLButtonElement &&
      primaryNav instanceof HTMLElement
    ) {
      const setMenuOpen = (isOpen: boolean) => {
        navbar.classList.toggle("is-menu-open", isOpen);
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuToggle.setAttribute(
          "aria-label",
          isOpen
            ? (menuToggle.dataset.menuCloseLabel ?? "Close navigation menu")
            : (menuToggle.dataset.menuOpenLabel ?? "Open navigation menu"),
        );
      };

      menuToggle.addEventListener("click", () => {
        setMenuOpen(!navbar.classList.contains("is-menu-open"));
      });

      primaryNav.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement) {
          setMenuOpen(false);
        }
      });
    }
  }
</script>

<style>
  .header {
    inline-size: 100%;
    margin: 0 auto;
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    z-index: 10;
    padding-block-start: var(--spacing-4);
    padding-inline: 0;
  }

  .navbar {
    display: grid;
    inline-size: min(calc(100% - 2rem), var(--container-max));
    margin-inline: auto;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      "brand actions"
      "nav nav";
    align-items: center;
    align-content: center;
    column-gap: var(--spacing-4);
    row-gap: 0;
    padding: var(--spacing-3);
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-background-surface-card-80);
  }

  .navbar.is-menu-open {
    row-gap: var(--spacing-4);
  }

  .navbar-left {
    grid-area: brand;
    display: flex;
    align-items: center;
    gap: var(--spacing-6);
    min-inline-size: 0;
  }

  .brand {
    display: inline-flex;
    flex: none;
    align-items: center;
    min-inline-size: 0;
  }

  .brand-logo {
    inline-size: 6.875rem;
    block-size: 2.75rem;
    object-fit: contain;
  }

  .tagline {
    display: none;
    min-block-size: 2.75rem;
    align-content: center;
    gap: 0.125rem;
    padding-inline-start: var(--spacing-6);
    border-inline-start: var(--border-hairline) solid
      var(--color-border-navbar-stroke);
    color: var(--color-text-muted-dark);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-14);
    line-height: var(--line-height-130);
    letter-spacing: var(--letter-spacing-caption);
    white-space: nowrap;
  }

  .primary-nav {
    grid-area: nav;
    display: none;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-4);
    padding-block-start: var(--spacing-4);
    border-block-start: var(--border-hairline) solid
      var(--color-border-navbar-stroke);
    color: var(--color-text-on-brand);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-16);
    line-height: var(--line-height-130);
    letter-spacing: var(--letter-spacing-label);
  }

  .navbar.is-menu-open .primary-nav {
    display: flex;
  }

  .primary-nav a:hover,
  .primary-nav a:focus-visible {
    color: var(--color-text-accent);
  }

  .navbar-actions {
    grid-area: actions;
    justify-self: end;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--spacing-3);
  }

  .language-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-inverse-muted);
    font-family: "Atkinson Hyperlegible", sans-serif;
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-label);
    line-height: var(--line-height-130);
    letter-spacing: var(--letter-spacing-wider);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .language-toggle:hover,
  .language-toggle:focus-visible {
    color: var(--color-text-accent);
  }

  .language-toggle:focus-visible,
  .menu-toggle:focus-visible {
    outline: var(--border-medium) solid var(--color-text-accent);
    outline-offset: var(--spacing-1);
  }

  .language-toggle:focus:not(:focus-visible) {
    outline: none;
  }

  .contact-action {
    display: none;
  }

  .contact-action :global(.header-contact) {
    min-inline-size: 7.75rem;
    block-size: 3rem;
    min-block-size: 3rem;
    justify-content: flex-start;
    gap: 0;
    padding: 0;
    border-width: var(--border-hairline);
    border-color: var(--color-red-50);
    border-radius: var(--radius-sm);
    color: var(--color-red-50);
    font-size: var(--font-size-button);
    letter-spacing: var(--letter-spacing-label);
    box-shadow: 0 0.25rem 1.25rem 0 oklch(0% 0 0 / 24%);
  }

  .contact-action :global(.header-contact:hover),
  .contact-action :global(.header-contact:focus-visible) {
    border-color: var(--color-amber);
    color: var(--color-amber);
  }

  .contact-action :global(.header-contact .button-label) {
    display: inline-flex;
    align-items: center;
    block-size: 100%;
    padding-inline-start: var(--spacing-6);
    line-height: var(--line-height-130);
    white-space: nowrap;
  }

  .contact-action :global(.header-contact .button-icon-area) {
    align-self: stretch;
    inline-size: var(--spacing-16);
  }

  .contact-action :global(.header-contact .button-icon) {
    inline-size: var(--size-icon-lg);
    block-size: var(--size-icon-lg);
    stroke-width: 1.35;
  }

  .menu-toggle {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
    inline-size: var(--size-control-md);
    block-size: var(--size-control-md);
    min-inline-size: var(--size-control-md);
    min-block-size: var(--size-control-md);
    padding: 0;
    border: var(--border-hairline) solid var(--color-red-50);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-red-50);
    cursor: pointer;
    overflow: clip;
    -webkit-tap-highlight-color: transparent;
  }

  .menu-toggle span {
    position: absolute;
    inset-inline-start: 50%;
    inline-size: 1.375rem;
    block-size: var(--border-hairline);
    border-radius: var(--radius-full);
    background: currentColor;
    transform: translateX(-50%);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .menu-toggle span:nth-child(1) {
    inset-block-start: 0.8125rem;
  }

  .menu-toggle span:nth-child(2) {
    inset-block-start: 1.3125rem;
  }

  .menu-toggle span:nth-child(3) {
    inset-block-start: 1.8125rem;
  }

  .menu-toggle:hover,
  .menu-toggle:focus-visible {
    border-color: var(--color-text-accent);
    color: var(--color-text-accent);
  }

  .navbar.is-menu-open .menu-toggle span:nth-child(1) {
    transform: translate(-50%, 0.5rem) rotate(45deg);
  }

  .navbar.is-menu-open .menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .navbar.is-menu-open .menu-toggle span:nth-child(3) {
    transform: translate(-50%, -0.5rem) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-toggle span {
      transition-duration: 0.01ms;
    }
  }

  @media (min-width: 48em) {
    .header {
      padding-block-start: var(--spacing-6);
    }

    .navbar {
      column-gap: var(--spacing-6);
      padding: var(--spacing-4);
      border: var(--border-hairline) solid var(--color-border-navbar-stroke);
      border-radius: var(--radius-md);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
    }

    .brand-logo {
      inline-size: 7.5rem;
      block-size: 2.9375rem;
    }

    .primary-nav {
      gap: var(--spacing-6);
      font-size: var(--font-size-nav-link);
    }

    .navbar-actions {
      gap: var(--spacing-4);
    }
  }

  @media (min-width: 64em) {
    .header {
      display: flex;
      justify-content: center;
      padding-block-start: var(--spacing-8);
    }

    .navbar {
      grid-template-columns: auto minmax(0, 1fr) auto;
      grid-template-areas: "brand nav actions";
      column-gap: 2.25rem;
      padding: var(--spacing-4);
      border-radius: var(--radius-lg);
    }

    .navbar-left {
      min-inline-size: 12.5rem;
    }

    .tagline {
      display: grid;
      color: var(--color-text-inverse-muted);
      font-weight: var(--font-weight-label);
    }

    .primary-nav {
      display: flex;
      justify-content: flex-end;
      padding: var(--spacing-3) var(--spacing-5);
      border-block-start: 0;
      border-radius: var(--radius-sm);
      font-weight: var(--font-weight-label);
    }

    .contact-action {
      display: block;
    }

    .menu-toggle {
      display: none;
    }

    .navbar-actions {
      gap: var(--spacing-3);
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import Header from "./layout/Header.astro";
import Hero from "./Hero.astro";
import About from "./About.astro";
import Solutions from "./Solutions.astro";
import Production from "./Production.astro";
import Footer from "./layout/Footer.astro";
import Partners from "./Partners.astro";
import { getSiteContent } from "../i18n/site";
import { normalizeLocale } from "../i18n/routing";

const { lang = "ro" } = Astro.props;
const locale = normalizeLocale(lang);
const meta = getSiteContent(locale).meta.home;
---

<Layout
  lang={locale}
  route="home"
  title={meta.title}
  description={meta.description}
>
  <Header lang={locale} route="home" />
  <main>
    <Hero lang={locale} />
    <Partners lang={locale} />
    <About lang={locale} />
    <Solutions lang={locale} />
    <Production lang={locale} />
  </main>
  <Footer lang={locale} route="home" />
</Layout>

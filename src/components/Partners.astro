---
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/typography.css";
import logoCfr from "../assets/partners/logo-cfr.svg";
import logoAlstom from "../assets/partners/logo-alstom.svg";
import logoSiemens from "../assets/partners/logo-siemens.svg";
import logoImsat from "../assets/partners/logo-imsat.svg";
import Eyebrow from "./ui/Eyebrow.astro";
import { getSiteContent } from "../i18n/site";
import { normalizeLocale } from "../i18n/routing";

const { lang = "ro" } = Astro.props;
const copy = getSiteContent(normalizeLocale(lang)).partners;

const partners = [
  {
    name: "CFR",
    logo: logoCfr,
    className: "partners-logo--cfr",
  },
  {
    name: "Alstom",
    logo: logoAlstom,
    className: "partners-logo--alstom",
  },
  {
    name: "Siemens",
    logo: logoSiemens,
    className: "partners-logo--siemens",
  },
  {
    name: "IMSAT",
    logo: logoImsat,
    className: "partners-logo--imsat",
  },
];
---

<section class="partners" aria-label={copy.sectionLabel}>
  <div class="partners-wrap">
    <Eyebrow decoration="red-on-dark">
      {copy.eyebrow}
    </Eyebrow>

    <div class="partners-logos" aria-label={copy.logosLabel}>
      {
        partners.map((partner, index) => (
          <>
            {index > 0 && (
              <span class="partners-separator" aria-hidden="true" />
            )}
            <div class={`partners-logo ${partner.className}`}>
              <img src={partner.logo.src} alt={partner.name} loading="lazy" />
            </div>
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partners {
    display: flex;
    flex-direction: column;
    align-items: center;
    inline-size: 100%;
    padding-block: var(--spacing-10);
    padding-inline: 0;
    background: var(--color-slate-900);
    color: var(--color-text-inverse-muted);
  }

  .partners-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-10);
    inline-size: 100%;
  }

  .partners :global(.eyebrow) {
    justify-content: center;
    inline-size: 17.0625rem;
    margin-block-end: 0;
  }

  .partners :global(.eyebrow .eyebrow-decoration) {
    display: none;
  }

  .partners :global(.eyebrow .eyebrow-content) {
    color: var(--color-text-inverse-muted);
    font-size: var(--font-size-20);
    line-height: var(--line-height-110);
    letter-spacing: var(--letter-spacing-label);
    text-align: center;
    white-space: nowrap;
  }

  .partners-logos {
    display: inline-grid;
    grid-template-columns: 9.375rem 8.125rem;
    grid-template-rows: repeat(2, auto);
    align-items: center;
    justify-content: center;
    gap: var(--spacing-8);
    inline-size: auto;
  }

  .partners-separator {
    display: none;
  }

  .partners-logo {
    display: grid;
    place-items: center;
    align-self: center;
    justify-self: center;
    inline-size: min(100%, 9.375rem);
  }

  .partners-logo img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: fill;
  }

  .partners-logo--cfr {
    grid-column: 1;
    grid-row: 1;
    inline-size: 8.125rem;
    block-size: 2.25rem;
  }

  .partners-logo--alstom {
    grid-column: 2;
    grid-row: 1;
    inline-size: 9.375rem;
    block-size: 2.25rem;
  }

  .partners-logo--siemens {
    grid-column: 1;
    grid-row: 2;
    inline-size: 9.375rem;
    block-size: 1.9375rem;
  }

  .partners-logo--imsat {
    grid-column: 2;
    grid-row: 2;
    inline-size: 8.125rem;
    block-size: 1.4083rem;
  }

  @media (min-width: 48em) {
    .partners {
      background: var(--color-sapphire);
      padding-block: var(--spacing-10);
      padding-inline: clamp(var(--spacing-16), 8.33vw, 7.5rem);
    }

    .partners-wrap {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-10);
      inline-size: min(100%, 75rem);
      block-size: var(--spacing-10);
    }

    .partners :global(.eyebrow) {
      justify-content: flex-start;
      gap: var(--spacing-4);
      inline-size: 21.25rem;
      block-size: 1.25rem;
      margin-block-end: 0;
    }

    .partners :global(.eyebrow .eyebrow-decoration) {
      display: inline-flex;
    }

    .partners :global(.eyebrow .eyebrow-content) {
      color: var(--color-text-inverse-muted);
      font-size: var(--font-size-20);
      line-height: var(--line-height-110);
      letter-spacing: var(--letter-spacing-label);
      white-space: nowrap;
    }

    .partners-logos {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: var(--spacing-7);
      inline-size: auto;
      block-size: var(--spacing-10);
    }

    .partners-separator {
      display: block;
      flex: none;
      inline-size: var(--border-hairline);
      block-size: var(--spacing-10);
      background: var(--color-slate-700);
    }

    .partners-logo {
      flex: none;
      grid-column: auto;
      grid-row: auto;
      inline-size: 8.125rem;
    }

    .partners-logo img {
      object-fit: fill;
    }

    .partners-logo--cfr {
      inline-size: 5.5rem;
      block-size: var(--spacing-10);
    }

    .partners-logo--alstom {
      inline-size: 8.125rem;
      block-size: 2.25rem;
    }

    .partners-logo--siemens {
      inline-size: 8.125rem;
      block-size: 1.9375rem;
    }

    .partners-logo--imsat {
      inline-size: 8.125rem;
      block-size: 1.625rem;
    }
  }
</style>

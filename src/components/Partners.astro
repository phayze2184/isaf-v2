---
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/typography.css";
import logoCfr from "../assets/partners/logo-cfr.svg";
import logoAlstom from "../assets/partners/logo-alstom.svg";
import logoSiemens from "../assets/partners/logo-siemens.svg";
import logoImsat from "../assets/partners/logo-imsat.svg";
import EyebrowText from "./ui/EyebrowText.astro";

const partners = [
  {
    name: "CFR",
    logo: logoCfr,
    className: "partners-logo--cfr",
  },
  {
    name: "Alstom",
    logo: logoAlstom,
    className: "partners-logo--alstom",
  },
  {
    name: "Siemens",
    logo: logoSiemens,
    className: "partners-logo--siemens",
  },
  {
    name: "IMSAT",
    logo: logoImsat,
    className: "partners-logo--imsat",
  },
];
---

<section class="partners" aria-labelledby="partners-title">
  <div class="partners-wrap">
    <EyebrowText class="partners-eyebrow" decoration="red-line" tone="dark">
      Parteneriate strategice
    </EyebrowText>

    <div class="partners-logos" aria-label="Parteneri strategici">
      {
        partners.map((partner, index) => (
          <>
            {index > 0 && <span class="partners-separator" aria-hidden="true"></span>}
            <div class={`partners-logo ${partner.className}`}>
              <img src={partner.logo.src} alt={partner.name} loading="lazy" />
            </div>
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .partners {
    display: grid;
    place-items: center;
    inline-size: 100%;
    padding-block: var(--spacing-10);
    padding-inline: var(--spacing-10);
    background: var(--color-slate-900);
    color: var(--color-text-inverse-muted);
  }

  .partners-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-10);
    inline-size: min(100%, 75rem);
  }

  .partners-logos {
    display: grid;
    grid-template-columns: minmax(9.375rem, 1fr) minmax(9.375rem, 1fr);
    grid-template-rows: auto auto;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-3);
    inline-size: min(100%, 18.25rem);
  }

  .partners-separator {
    display: none;
  }

  .partners-logo {
    display: grid;
    place-items: center;
    align-self: center;
    justify-self: center;
    inline-size: min(100%, 9.375rem);
  }

  .partners-logo img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: fill;
  }

  .partners-logo--cfr {
    grid-column: 1;
    grid-row: 1;
    inline-size: 9.375rem;
    block-size: 3.75rem;
  }

  .partners-logo--alstom {
    grid-column: 2;
    grid-row: 1;
    inline-size: 8.125rem;
    block-size: 2.25rem;
  }

  .partners-logo--siemens {
    grid-column: 1;
    grid-row: 2;
    inline-size: 9.375rem;
    block-size: 1.9375rem;
  }

  .partners-logo--imsat {
    grid-column: 2;
    grid-row: 2;
    inline-size: 8.125rem;
    block-size: 1.4083rem;
  }

  @media (min-width: 48em) {
    .partners {
      background: var(--color-sapphire);
      padding-block: var(--spacing-15);
      padding-inline: clamp(var(--spacing-16), 8.33vw, 7.5rem);
    }

    .partners-wrap {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-16);
      block-size: var(--spacing-10);
    }

    .partners-eyebrow {
      justify-content: flex-start;
      gap: var(--spacing-4);
      inline-size: 21.25rem;
      block-size: 1.25rem;
    }

    .partners-eyebrow-line {
      display: block;
      flex: none;
      inline-size: var(--spacing-10);
      block-size: 0.375rem;
      border-radius: var(--radius-full);
      background: var(--color-red);
    }

    .partners-eyebrow p {
      justify-content: flex-start;
      text-align: start;
    }

    .partners-logos {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: var(--spacing-7);
      inline-size: auto;
    }

    .partners-separator {
      display: block;
      flex: none;
      inline-size: var(--border-hairline);
      block-size: var(--spacing-10);
      background: var(--color-slate-700);
    }

    .partners-logo {
      flex: none;
      grid-column: auto;
      grid-row: auto;
      inline-size: 8.125rem;
    }

    .partners-logo img {
      object-fit: fill;
    }

    .partners-logo--cfr {
      inline-size: 5.5rem;
      block-size: var(--spacing-10);
    }

    .partners-logo--alstom {
      inline-size: 8.125rem;
      block-size: 2.25rem;
    }

    .partners-logo--siemens {
      inline-size: 8.125rem;
      block-size: 1.9375rem;
    }

    .partners-logo--imsat {
      inline-size: 8.125rem;
      block-size: 1.625rem;
    }
  }
</style>

---
import "../styles/tokens.css";
import "../styles/global.css";
import "../styles/typography.css";
import galleryMobileImage1 from "../assets/images/gallery-mobile-1.jpg";
import galleryMobileImage2 from "../assets/images/gallery-mobile-2.jpg";
import galleryMobileImage3 from "../assets/images/gallery-mobile-3.jpg";
import galleryMobileImage4 from "../assets/images/gallery-mobile-4.jpg";
import galleryMobileImage5 from "../assets/images/gallery-mobile-5.jpg";
import galleryDesktopImage1 from "../assets/images/gallery-desktop-1.jpg";
import galleryDesktopImage2 from "../assets/images/gallery-desktop-2.jpg";
import galleryDesktopImage3 from "../assets/images/gallery-desktop-3.jpg";
import galleryDesktopImage4 from "../assets/images/gallery-desktop-4.jpg";
import galleryDesktopImage5 from "../assets/images/gallery-desktop-5.jpg";
import elementProdHeader from "../assets/svg/element-prod-header.svg";
import Eyebrow from "./ui/Eyebrow.astro";
import GalleryNavigation from "./ui/GalleryNavigation.astro";
import StatCard from "./ui/StatCard.astro";
import { getSiteContent } from "../i18n/site";
import { normalizeLocale } from "../i18n/routing";

const { lang = "ro" } = Astro.props;

const commonGalleryImages = [
  { mobile: galleryMobileImage1, desktop: galleryDesktopImage1 },
  { mobile: galleryMobileImage2, desktop: galleryDesktopImage2 },
  { mobile: galleryMobileImage3, desktop: galleryDesktopImage3 },
  { mobile: galleryMobileImage4, desktop: galleryDesktopImage4 },
  { mobile: galleryMobileImage5, desktop: galleryDesktopImage5 },
];

const copy = getSiteContent(normalizeLocale(lang)).production;

const galleryImages = commonGalleryImages.map((image, index) => ({
  ...image,
  alt: copy.galleryAlts[index],
}));
---

<section
  class="production section"
  id="production"
  aria-labelledby="production-title"
>
  <div class="production-inner">
    <div class="section-left">
      <header class="production-header">
        <div class="production-heading">
          <Eyebrow decoration="gray-on-light">
            {copy.eyebrow}
          </Eyebrow>
          <h2 id="production-title">
            {copy.title}
          </h2>
        </div>

        <p class="production-intro">
          {copy.intro}
        </p>

        <img
          class="production-intro-decoration"
          src={elementProdHeader.src}
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
      </header>

      <StatCard
        class="production-kpis production-kpis--mobile"
        items={copy.mobileKpis}
      />
      <StatCard
        class="production-kpis production-kpis--desktop"
        items={copy.desktopKpis}
      />
    </div>

    <div
      class="production-content"
      data-production-gallery
      data-counter-separator={copy.counterSeparator}
    >
      {
        galleryImages.map((image, index) => (
          <figure
            class:list={["production-frame", index === 0 && "is-active"]}
            data-production-slide
            aria-hidden={index === 0 ? "false" : "true"}
          >
            <picture>
              <source
                srcset={image.desktop.src}
                media="(min-width: 48em)"
                width={image.desktop.width}
                height={image.desktop.height}
              />
              <img
                src={image.mobile.src}
                alt={image.alt}
                width={image.mobile.width}
                height={image.mobile.height}
                loading={index === 0 ? "eager" : "lazy"}
              />
            </picture>
          </figure>
        ))
      }

      <GalleryNavigation
        class="production-controls"
        current={1}
        total={galleryImages.length}
        navigationLabel={copy.navigationLabel}
        counterSeparator={copy.counterSeparator}
        previousLabel={copy.previousImage}
        nextLabel={copy.nextImage}
        previousDisabled={true}
        nextDisabled={galleryImages.length <= 1}
      />

      <div class="production-swipe" aria-hidden="true">
        <span class="production-swipe-dots">
          {
            galleryImages.map((_, index) => (
              <span
                class:list={[
                  "production-swipe-dot",
                  index === 0 && "is-active",
                ]}
                data-production-dot
              />
            ))
          }
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  {
    const gallery = document.querySelector("[data-production-gallery]");

    if (gallery) {
      const counterSeparator =
        gallery instanceof HTMLElement && gallery.dataset.counterSeparator
          ? gallery.dataset.counterSeparator
          : "din";
      const slides = Array.from(
        gallery.querySelectorAll("[data-production-slide]"),
      );
      const prevButton = gallery.querySelector("[data-gallery-prev]");
      const nextButton = gallery.querySelector("[data-gallery-next]");
      const counter = gallery.querySelector("[data-gallery-counter]");
      const currentCount = gallery.querySelector("[data-gallery-current]");
      const dots = Array.from(
        gallery.querySelectorAll("[data-production-dot]"),
      );
      let touchStartX = 0;
      let touchStartY = 0;
      let activeIndex = 0;

      const formatCount = (value: number | string) =>
        String(value).padStart(2, "0");
      const totalCount = formatCount(slides.length);

      const updateGallery = () => {
        slides.forEach((slide, index) => {
          const isActive = index === activeIndex;
          slide.classList.toggle("is-active", isActive);
          slide.setAttribute("aria-hidden", String(!isActive));
        });

        if (currentCount) {
          const currentValue = formatCount(activeIndex + 1);
          currentCount.textContent = currentValue;
          counter?.setAttribute(
            "aria-label",
            `${currentValue} ${counterSeparator} ${totalCount}`,
          );
        }

        if (prevButton instanceof HTMLButtonElement) {
          prevButton.disabled = activeIndex === 0;
        }

        if (nextButton instanceof HTMLButtonElement) {
          nextButton.disabled = activeIndex === slides.length - 1;
        }

        dots.forEach((dot, index) => {
          dot.classList.toggle("is-active", index === activeIndex);
        });
      };

      prevButton?.addEventListener("click", () => {
        activeIndex = Math.max(0, activeIndex - 1);
        updateGallery();
      });

      nextButton?.addEventListener("click", () => {
        activeIndex = Math.min(slides.length - 1, activeIndex + 1);
        updateGallery();
      });

      gallery.addEventListener(
        "touchstart",
        (event) => {
          if (!(event instanceof TouchEvent)) {
            return;
          }

          const touch = event.changedTouches[0];
          touchStartX = touch.clientX;
          touchStartY = touch.clientY;
        },
        { passive: true },
      );

      gallery.addEventListener(
        "touchend",
        (event) => {
          if (!(event instanceof TouchEvent)) {
            return;
          }

          const touch = event.changedTouches[0];
          const deltaX = touch.clientX - touchStartX;
          const deltaY = touch.clientY - touchStartY;

          if (Math.abs(deltaX) < 40 || Math.abs(deltaX) < Math.abs(deltaY)) {
            return;
          }

          activeIndex =
            deltaX < 0
              ? Math.min(slides.length - 1, activeIndex + 1)
              : Math.max(0, activeIndex - 1);
          updateGallery();
        },
        { passive: true },
      );
    }
  }
</script>

<style>
  .production {
    display: flex;
    justify-content: center;
    background: var(--color-slate-300);
    color: var(--color-text-default);
  }

  .production-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-14);
    inline-size: min(100%, 24.5625rem);
    padding-inline: 0;
  }

  .section-left {
    display: contents;
  }

  .production-header {
    position: relative;
    order: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-6);
    inline-size: 100%;
    padding-inline: var(--spacing-6);
  }

  .production-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-3);
    inline-size: 100%;
  }

  .production :global(.eyebrow) {
    margin-block-end: 0;
  }

  .production :global(.eyebrow .eyebrow-content) {
    color: var(--color-text-muted-light);
    line-height: var(--line-height-110);
    letter-spacing: var(--letter-spacing-label);
  }

  .production h2 {
    display: flex;
    align-items: center;
    max-inline-size: 21.3125rem;
    min-block-size: 5.5rem;
    color: var(--color-text-default);
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-heading);
    line-height: var(--line-height-h2);
    letter-spacing: var(--letter-spacing-heading);
  }

  .production-intro {
    position: relative;
    max-inline-size: 21.3125rem;
    color: var(--color-text-muted-light);
    font-size: var(--font-size-18);
    line-height: var(--line-height-body);
  }

  .production-intro-decoration {
    position: absolute;
    inset-block-end: -2.0625rem;
    inset-inline-end: 2.625rem;
    inline-size: 8.40625rem;
    block-size: 1.03125rem;
    object-fit: contain;
    pointer-events: none;
  }

  .production-content {
    position: relative;
    order: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .production :global(.stat-cards) {
    order: 3;
  }

  .production :global(.production-kpis) {
    inline-size: calc(100% - (var(--spacing-6) * 2));
  }

  .production :global(.production-kpis--desktop) {
    display: none;
  }

  .production-frame {
    position: relative;
    inline-size: 100vw;
    block-size: 28.5rem;
    overflow: hidden;
    margin: 0;
    border-radius: var(--radius-md);
    background: var(--color-slate-600);
  }

  .production-frame:not(.is-active) {
    display: none;
  }

  .production-frame::before,
  .production-frame::after {
    position: absolute;
    content: "";
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .production-frame::before {
    z-index: 1;
    background: linear-gradient(
      180deg,
      oklch(0% 0 0 / 26%) 0%,
      oklch(0% 0 0 / 8%) 50%,
      oklch(7.271% 0.0107 260.729 / 64%) 100%
    );
  }

  .production-frame::after {
    z-index: 2;
    background: url("data:image/svg+xml;utf8,<svg viewBox='0 0 393 456' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='none'><rect x='0' y='0' height='100%25' width='100%25' fill='url(%23grad)' opacity='0.30000001192092896'/><defs><radialGradient id='grad' gradientUnits='userSpaceOnUse' cx='0' cy='0' r='10' gradientTransform='matrix(1.2032e-15 22.8 -19.65 1.3961e-15 196.5 228)'><stop stop-color='rgba(255,255,255,0.7)' offset='0'/><stop stop-color='rgba(191,191,191,0.75)' offset='0.25'/><stop stop-color='rgba(159,159,159,0.775)' offset='0.375'/><stop stop-color='rgba(128,128,128,0.8)' offset='0.5'/><stop stop-color='rgba(96,96,96,0.75)' offset='0.625'/><stop stop-color='rgba(64,64,64,0.7)' offset='0.75'/><stop stop-color='rgba(32,32,32,0.65)' offset='0.875'/><stop stop-color='rgba(16,16,16,0.625)' offset='0.9375'/><stop stop-color='rgba(0,0,0,0.6)' offset='1'/></radialGradient></defs></svg>");
    background-size: 100% 100%;
    mix-blend-mode: multiply;
  }

  .production-frame picture,
  .production-frame img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
  }

  .production-frame img {
    object-fit: cover;
  }

  .production :global(.production-controls) {
    position: absolute;
    inset-block-start: auto;
    inset-block-end: var(--spacing-8);
    inset-inline: auto var(--spacing-8);
    z-index: 3;
    display: none;
    align-items: center;
    justify-content: space-between;
    transform: none;
    pointer-events: none;
    inline-size: auto;
  }

  .production-swipe {
    position: absolute;
    inset-block-end: var(--spacing-5);
    inset-inline-start: 50%;
    z-index: 3;
    display: flex;
    align-items: center;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .production-swipe-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
  }

  .production-swipe-dot {
    inline-size: 0.375rem;
    block-size: 0.375rem;
    border-radius: var(--radius-full);
    background: oklch(100% 0 0 / 45%);
  }

  .production-swipe-dot.is-active {
    inline-size: 1.125rem;
    background: var(--color-red);
  }

  @media (min-width: 48em) {
    .production-inner {
      inline-size: min(100%, 76rem);
      align-items: stretch;
    }

    .production-header {
      align-self: center;
      inline-size: min(100%, 45rem);
    }

    .production-frame {
      inline-size: min(100%, 45rem);
    }

    .production :global(.stat-cards) {
      align-self: center;
    }

    .production :global(.production-controls) {
      display: flex;
    }

    .production-swipe {
      display: none;
    }
  }

  @media (min-width: 64em) {
    .production-inner {
      display: grid;
      grid-template-columns: 29.9375rem 37.4375rem;
      align-items: start;
      justify-content: space-between;
      column-gap: 7.625rem;
      inline-size: min(100%, 75rem);
      block-size: 48.4375rem;
      max-inline-size: 75rem;
      padding-inline: 0;
    }

    .section-left {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      align-items: flex-start;
      align-self: end;
      inline-size: 29.9375rem;
      block-size: auto;
    }

    .production-header {
      align-self: start;
      inline-size: 100%;
      block-size: 7.875rem;
      margin-block-start: 0;
      gap: 0;
      padding-inline: 0;
    }

    .production-heading {
      gap: 1.125rem;
    }

    .production :global(.eyebrow) {
      --eyebrow-content-font-size: var(--font-size-20);
    }

    .production h2 {
      display: flex;
      align-items: center;
      max-inline-size: 29.9375rem;
      block-size: 5.5rem;
      font-size: var(--font-size-h2);
      font-weight: var(--font-weight-heading);
      line-height: var(--line-height-h2);
      letter-spacing: var(--letter-spacing-heading);
    }

    .production-intro {
      display: none;
    }

    .production-intro-decoration {
      display: none;
    }

    .production-content {
      position: relative;
      align-self: start;
      display: block;
      inline-size: 37.4375rem;
      block-size: 48.4375rem;
      min-block-size: 0;
      overflow: hidden;
      border-radius: var(--radius-md);
    }

    .production-frame {
      inline-size: 100%;
      block-size: 100%;
      border-radius: inherit;
    }

    .production-frame::before,
    .production-frame::after {
      position: absolute;
      content: "";
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
    }

    .production-frame::before {
      z-index: 1;
      background: linear-gradient(
        180deg,
        oklch(0% 0 0 / 26%) 0%,
        oklch(0% 0 0 / 8%) 50%,
        oklch(7.271% 0.0107 260.729 / 64%) 100%
      );
    }

    .production-frame::after {
      z-index: 2;
      background: url("data:image/svg+xml;utf8,<svg viewBox='0 0 599 775' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='none'><rect x='0' y='0' height='100%25' width='100%25' fill='url(%23grad)' opacity='0.30000001192092896'/><defs><radialGradient id='grad' gradientUnits='userSpaceOnUse' cx='0' cy='0' r='10' gradientTransform='matrix(1.8339e-15 38.75 -29.95 2.3728e-15 299.5 387.5)'><stop stop-color='rgba(255,255,255,0.7)' offset='0'/><stop stop-color='rgba(191,191,191,0.75)' offset='0.25'/><stop stop-color='rgba(159,159,159,0.775)' offset='0.375'/><stop stop-color='rgba(128,128,128,0.8)' offset='0.5'/><stop stop-color='rgba(96,96,96,0.75)' offset='0.625'/><stop stop-color='rgba(64,64,64,0.7)' offset='0.75'/><stop stop-color='rgba(32,32,32,0.65)' offset='0.875'/><stop stop-color='rgba(16,16,16,0.625)' offset='0.9375'/><stop stop-color='rgba(0,0,0,0.6)' offset='1'/></radialGradient></defs></svg>");
      background-size: 100% 100%;
      mix-blend-mode: multiply;
    }

    .production-frame img {
      object-position: 39% center;
    }

    .production :global(.production-controls) {
      position: absolute;
      inset-block-start: auto;
      inset-block-end: 2.1875rem;
      inset-inline: auto 2.625rem;
      z-index: 3;
      transform: none;
      pointer-events: none;
      inline-size: auto;
    }

    .production :global(.stat-cards) {
      align-self: start;
    }

    .production :global(.production-kpis) {
      inline-size: 29.9375rem;
    }

    .production :global(.production-kpis--mobile) {
      display: none;
    }

    .production :global(.production-kpis--desktop) {
      display: flex;
    }
  }
</style>

---
import "../../styles/tokens.css";
import "../../styles/typography.css";

const {
  current = 1,
  total = 6,
  class: className,
  navigationLabel = "Navigare galerie",
  counterSeparator = "din",
  previousLabel = "Imaginea anterioară",
  nextLabel = "Imaginea următoare",
  previousDisabled = true,
  nextDisabled = false,
} = Astro.props;

const formatCount = (value: number | string) => String(value).padStart(2, "0");
const currentCount = formatCount(current);
const totalCount = formatCount(total);
---

<div class={`gallery-navigation ${className ?? ""}`} aria-label={navigationLabel}>
  <div class="gallery-navigation-frame" aria-hidden="true">
    <svg viewBox="0 0 172 189" focusable="false">
      <path class="frame-path" d="M28 1H139L171 40V188H39L1 143V45" />
      <path class="frame-accent" d="M10 0V18M1 9H19" />
    </svg>
  </div>

  <div class="gallery-navigation-content">
    <div class="gallery-navigation-text-line">
      <div
        class="gallery-navigation-counter"
        aria-label={`${currentCount} ${counterSeparator} ${totalCount}`}
        data-gallery-counter
      >
        <span class="gallery-navigation-current" data-gallery-current>{currentCount}</span>
        <span class="gallery-navigation-divider" aria-hidden="true"></span>
        <span class="gallery-navigation-total">{totalCount}</span>
      </div>

      <span class="gallery-navigation-line" aria-hidden="true">
        <svg viewBox="0 0 124 13" focusable="false">
          <path d="M0 12H100L124 1" />
          <circle cx="1" cy="12" r="1.5" />
        </svg>
      </span>
    </div>

    <div class="gallery-navigation-buttons">
      <button
        class="gallery-navigation-button gallery-navigation-button--previous"
        type="button"
        aria-label={previousLabel}
        disabled={previousDisabled}
        data-gallery-prev
      >
        <span class="gallery-navigation-icon" aria-hidden="true">
          <svg viewBox="0 0 23 24" focusable="false">
            <path d="M14.5 6.5L8 12L14.5 17.5" />
            <path d="M8 12H21" />
          </svg>
        </span>
      </button>

      <button
        class="gallery-navigation-button gallery-navigation-button--next"
        type="button"
        aria-label={nextLabel}
        disabled={nextDisabled}
        data-gallery-next
      >
        <span class="gallery-navigation-icon" aria-hidden="true">
          <svg viewBox="0 0 23 24" focusable="false">
            <path d="M8.5 6.5L15 12L8.5 17.5" />
            <path d="M2 12H15" />
          </svg>
        </span>
      </button>
    </div>
  </div>
</div>

<style>
  .gallery-navigation {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    inline-size: 10.125rem;
    block-size: 11.125rem;
    padding: var(--spacing-8) 0.8125rem;
    color: var(--color-text-muted-dark);
    pointer-events: none;
  }

  .gallery-navigation-frame {
    position: absolute;
    inset-block-start: -0.66875rem;
    inset-inline-start: -1.05875rem;
    inline-size: 10.763875rem;
    block-size: 11.79375rem;
    pointer-events: none;
  }

  .gallery-navigation-frame svg {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    fill: none;
  }

  .frame-path {
    stroke: var(--color-slate-400);
    stroke-width: var(--border-hairline);
  }

  .frame-accent {
    stroke: var(--color-red);
    stroke-width: var(--border-medium);
    stroke-linecap: square;
  }

  .gallery-navigation-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-4);
    inline-size: 8.5rem;
  }

  .gallery-navigation-text-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }

  .gallery-navigation-counter {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 0.375rem;
  }

  .gallery-navigation-current,
  .gallery-navigation-total {
    font-family: "Big Shoulders", sans-serif;
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-110);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .gallery-navigation-current {
    color: var(--color-text-muted-dark);
    font-size: var(--font-size-32);
    letter-spacing: var(--letter-spacing-eyebrow);
  }

  .gallery-navigation-total {
    color: var(--color-slate-400);
    font-size: var(--font-size-24);
    letter-spacing: var(--letter-spacing-widest);
  }

  .gallery-navigation-divider {
    inline-size: 0.0625rem;
    block-size: 1.25rem;
    margin-block-end: 0.125rem;
    background: var(--color-slate-400);
    transform: rotate(25deg);
    transform-origin: center;
  }

  .gallery-navigation-line {
    display: block;
    inline-size: 7.753rem;
    block-size: 0.80825rem;
    transform: scaleY(-1);
  }

  .gallery-navigation-line svg {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    fill: none;
  }

  .gallery-navigation-line path,
  .gallery-navigation-line circle {
    stroke: var(--color-slate-400);
    fill: var(--color-slate-400);
    stroke-width: var(--border-hairline);
  }

  .gallery-navigation-buttons {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    inline-size: 6.625rem;
    block-size: var(--spacing-10);
  }

  .gallery-navigation-button {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    min-inline-size: 0;
    inline-size: 2.875rem;
    block-size: 2.75rem;
    overflow: hidden;
    padding: 0.625rem var(--spacing-3);
    border: var(--border-hairline) solid var(--color-slate-50);
    border-radius: var(--radius-xs);
    background: transparent;
    color: var(--color-slate-50);
    cursor: pointer;
    pointer-events: auto;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .gallery-navigation-button--next {
    border-color: var(--color-red);
    background: var(--color-red);
  }

  .gallery-navigation-button:hover:not(:disabled),
  .gallery-navigation-button:focus-visible {
    background: oklch(57.0462% 0.2322 26.6369 / 10%);
  }

  .gallery-navigation-button:focus-visible {
    outline: var(--border-medium) solid var(--color-amber);
    outline-offset: var(--spacing-1);
  }

  .gallery-navigation-button:active {
    transform: scale(0.96);
  }

  .gallery-navigation-button:disabled {
    cursor: default;
  }

  .gallery-navigation-icon {
    display: block;
    inline-size: 1.4375rem;
    block-size: 1.5rem;
  }

  .gallery-navigation-icon svg {
    inline-size: 100%;
    block-size: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: var(--border-hairline);
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-navigation-button {
      transition-duration: 0.01ms;
    }
  }
</style>

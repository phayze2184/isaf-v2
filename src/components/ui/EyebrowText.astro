---
const {
  class: className,
  decoration = "red-line",
  tone = "light",
} = Astro.props;

const eyebrowDecoration =
  decoration === "gray-line" ? "gray-line" : "red-line";
const eyebrowTone = tone === "dark" ? "on-dark" : "on-light";
---

<div class={`eyebrow eyebrow--${eyebrowDecoration} eyebrow--${eyebrowTone} ${className ?? ""}`}>
  <span class="eyebrow-decoration" aria-hidden="true">
    <span class="eyebrow-line"></span>
  </span>
  <p class="eyebrow-content">
    <slot>Experți în infrastructură feroviară</slot>
  </p>
</div>

<style> 
  .eyebrow {
    --eyebrow-content-color: var(--color-text-muted-light);

    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
    max-width: 100%;
    margin-bottom: clamp(var(--spacing-5), calc(0.5rem + 1vw), var(--spacing-7));
  }

  .eyebrow-decoration {
    display: inline-flex;
    align-items: center;
    flex: none;
  }

  .eyebrow-content {
    margin: 0;
    color: var(--eyebrow-content-color);
    font-family: "Atkinson Hyperlegible Mono", monospace;
    font-size: clamp(
      var(--font-size-caption),
      calc(0.5rem + 1vw),
      var(--font-size-eyebrow)
    );
    font-style: normal;
    font-weight: var(--font-weight-label);
    line-height: var(--line-height-label);
    letter-spacing: var(--letter-spacing-eyebrow);
    text-transform: uppercase;
  }

  .eyebrow-line {
    inline-size: var(--spacing-6);
    block-size: var(--border-strong);
    flex: none;
    border-radius: var(--radius-full);
    background: var(--color-red);
  }

  .eyebrow--gray-line {
    inline-size: min(100%, 29.625rem);
  }

  .eyebrow--gray-line .eyebrow-content {
    --eyebrow-content-color: var(--color-text-inverse-muted);

    font-size: var(--font-size-label);
  }

  .eyebrow--on-dark .eyebrow-content {
    --eyebrow-content-color: var(--color-text-muted-dark);
  }

  .eyebrow--gray-line .eyebrow-line {
    inline-size: var(--spacing-10);
    block-size: var(--border-hairline);
    border-radius: 0;
    background: var(--color-slate-500);
  }

  @media (min-width: 48em) {
    .eyebrow-content {
      max-inline-size: 25rem;
    }

    .eyebrow--red-line .eyebrow-line {
      inline-size: var(--spacing-8);
    }
  }
</style>
